# ─────────────────────────────────────────────────────────────────────────────
# Site Snap — Environment Variable Reference
# Copy this file to .env (never commit .env) and fill in real values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Node ─────────────────────────────────────────────────────────────────────

# Runtime environment. Set to "production" on Railway/Neon deployments.
# Controls CSP headers, rate limiting, and pool sizing.
NODE_ENV=development

# ── API Server ───────────────────────────────────────────────────────────────

# TCP port the Express API server binds to.
# Railway injects this automatically; set manually for local dev.
PORT=8080

# Random 32+ character string used to sign session cookies.
# Generate with: openssl rand -hex 32
SESSION_SECRET=replace_with_a_random_32_char_string_here

# Log verbosity. Accepted values: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Milliseconds threshold above which a slow SQL query is logged as a warning.
SLOW_QUERY_THRESHOLD_MS=500

# ── Public app domain ────────────────────────────────────────────────────────

# Fully-qualified base URL of the deployed app (no trailing slash).
# Used to build webhook callback URLs, referral links, and OAuth redirect URIs.
# On Railway: set to your Railway service public URL, e.g. https://api.myapp.com
# On Replit: leave unset — REPLIT_DOMAINS is used as the automatic fallback.
APP_BASE_URL=https://api.example.com

# ── Database (Neon / PostgreSQL) ──────────────────────────────────────────────

# PostgreSQL connection string.
# Neon: use the "pooled" connection string from the Neon console (port 5432, ?sslmode=require).
# Local: postgres://user:password@localhost:5432/sitesnap
DATABASE_URL=postgres://user:password@localhost:5432/sitesnap

# ── Clerk (Authentication) ────────────────────────────────────────────────────

# Clerk publishable key — safe to expose to browsers.
# Found in: Clerk dashboard → API Keys
CLERK_PUBLISHABLE_KEY=pk_test_replace_me

# Clerk secret key — server-side only, never expose to the browser.
# Found in: Clerk dashboard → API Keys
CLERK_SECRET_KEY=sk_test_replace_me

# ── Web Dashboard (Vite) ──────────────────────────────────────────────────────

# Clerk publishable key for the Vite frontend (must match CLERK_PUBLISHABLE_KEY).
VITE_CLERK_PUBLISHABLE_KEY=pk_test_replace_me

# URL to the Clerk proxy endpoint served by the API server.
# Typically: <APP_BASE_URL>/api/__clerk
VITE_CLERK_PROXY_URL=https://api.example.com/api/__clerk

# Local-storage key used to cache the Clerk JWT for non-hook contexts.
VITE_TOKEN_KEY=sitesnap_token

# ── Mobile (Expo) ─────────────────────────────────────────────────────────────

# Clerk publishable key for the Expo app (must match CLERK_PUBLISHABLE_KEY).
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me

# Base domain the Expo app calls for API requests (no trailing slash, no /api).
EXPO_PUBLIC_DOMAIN=https://api.example.com

# ── Email (Resend) ────────────────────────────────────────────────────────────

# API key for the Resend email delivery service.
# Found in: resend.com → API Keys
RESEND_API_KEY=re_replace_me

# ── Stripe (Billing) ─────────────────────────────────────────────────────────

# Stripe secret key. Use sk_test_* for development, sk_live_* for production.
# Found in: Stripe dashboard → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_replace_me

# Stripe webhook signing secret — used to verify incoming webhook payloads.
# Found in: Stripe dashboard → Developers → Webhooks → select endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# ── QuickBooks (Accounting Integration) ──────────────────────────────────────

# OAuth 2.0 Client ID for the QuickBooks / Intuit app.
# Found in: Intuit Developer portal → your app → Keys & OAuth
QB_CLIENT_ID=replace_me

# OAuth 2.0 Client Secret for the QuickBooks / Intuit app.
QB_CLIENT_SECRET=replace_me

# ── Twilio (SMS Notifications) ───────────────────────────────────────────────

# Twilio account identifier.
# Found in: twilio.com/console → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio auth token — server-side only, never expose to the browser.
# Found in: twilio.com/console → Account Info
TWILIO_AUTH_TOKEN=replace_me

# ── AI / OpenAI (via Replit AI Integrations proxy) ────────────────────────────

# Injected automatically by the Replit AI Integrations proxy.
# On Railway/Neon: set to your OpenAI API key (https://platform.openai.com/api-keys).
AI_INTEGRATIONS_OPENAI_API_KEY=sk-replace_me

# Base URL for the OpenAI-compatible endpoint.
# Replit proxy: set automatically. Railway: https://api.openai.com/v1
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# ── Web Search (Tavily) ───────────────────────────────────────────────────────

# API key for Tavily web search (used by the AI assistant).
# Found in: app.tavily.com → API Keys
TAVILY_API_KEY=tvly-replace_me

# ── Object Storage ────────────────────────────────────────────────────────────

# Directory prefix for private uploaded objects (receipts, attachments, etc.).
PRIVATE_OBJECT_DIR=private

# Comma-separated path prefixes that are publicly readable.
PUBLIC_OBJECT_SEARCH_PATHS=public

# Sidecar endpoint for Replit Object Storage token exchange.
# Override on Railway/Neon with a GCS-compatible endpoint or leave unset if
# migrating to a different storage provider.
# Default (Replit only): http://127.0.0.1:1106
OBJECT_STORAGE_ENDPOINT=http://127.0.0.1:1106

# ── CORS (development overrides) ─────────────────────────────────────────────

# Comma-separated list of additional origins allowed during local development.
# Defaults to http://localhost:5173,http://localhost:3000 when NODE_ENV != production.
# Set this on Railway if you need to allow extra staging origins.
CORS_DEV_ORIGINS=http://localhost:5173,http://localhost:3000
