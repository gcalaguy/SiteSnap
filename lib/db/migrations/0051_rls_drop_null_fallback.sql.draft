-- DRAFT — DO NOT RUN YET.
--
-- This file is intentionally named *.sql.draft (not *.sql) so it is never
-- picked up by a migration runner. Rename to 0051_rls_drop_null_fallback.sql
-- ONLY after ALL of the following are true:
--
--   1. Every test in tests/rls-tenant-isolation.test.ts passes (Phase 0 gate).
--   2. A manual audit confirms every route file that reads/writes a table in
--      the list below goes through requireTenantCtx — grep for the table's
--      Drizzle export across artifacts/api-server/src and check each call
--      site executes inside a withTenantCtx() transaction. Cron jobs, scripts,
--      and background workers count too — anything hitting these tables
--      outside a tenant transaction will silently see ZERO rows once this
--      migration runs (RESTRICTIVE with no escape hatch), not an error.
--   3. user_memberships and subscriptions are EXCLUDED below on purpose — see
--      migration 0050's header comment. Do not add them here until
--      requireAuth() no longer needs to read them before tenant context
--      exists (e.g. via a SECURITY DEFINER bootstrap function, or by moving
--      that lookup outside RLS entirely). Restricting them today would break
--      login for every user on every request.
--
-- WHAT THIS DOES: removes the `current_tenant_id() IS NULL OR` escape hatch
-- from every tenant_isolation policy (except the two listed above), and
-- removes the `company_id IS NULL OR` global-default clause is KEPT for
-- estimator_cost_models/estimator_addons — that one is a permanent product
-- behavior (system defaults visible to everyone), not a rollout safety net.
--
-- AFTER THIS RUNS: any query against these tables that isn't wrapped in
-- withTenantCtx() will see zero rows, not all rows. That is the point — this
-- is the actual lockdown. There is no more graceful degradation past this.

DO $$
BEGIN
  -- Standard direct company_id tables (51) — full RESTRICTIVE, no fallback.
  ALTER POLICY tenant_isolation ON ai_compliance_directives    USING (company_id = current_tenant_id());
  ALTER POLICY tenant_isolation ON asset_schedules             USING (company_id = current_tenant_id());
  ALTER POLICY tenant_isolation ON audit_logs                  USING (company_id = current_tenant_id());
  ALTER POLICY tenant_isolation ON builder_estimates           USING (company_id = current_tenant_id());
  ALTER POLICY tenant_isolation ON capa_tickets                USING (company_id = current_tenant_id());
  ALTER POLICY tenant_isolation ON change_orders               USING (company_id = current_tenant_id());
  ALTER POLICY tenant_isolation ON contacts                    USING (company_id = current_tenant_id());
  ALTER POLICY tenant_isolation ON conversations               USING (company_id = current_tenant_id());
