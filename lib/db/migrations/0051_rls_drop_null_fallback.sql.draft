  ALTER POLICY tenant_isolation ON cor_audit_trail             USING (company_id = current_tenant_id());
  ALTER POLICY tenant_isolation ON cor_voice_action_logs       USING (company_id = current_tenant_id());
  ALTER POLICY tenant_isolation ON credential_alert_logs       USING (company_id = current_tenant_id());
